{
  "name": "@solana/keychain-workspace",
  "version": "1.0.1",
  "private": true,
  "description": "Unified Solana transaction signing across multiple backends",
  "type": "module",
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "lint": "eslint packages --ext .ts",
    "lint:fix": "eslint packages --ext .ts --fix",
    "format": "prettier --write \"packages/**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,json,md}\"",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck",
    "test:treeshakability": "pnpm -r --filter '!@solana/keychain-test-utils' run test:treeshakability",
    "test:treeshakability:umbrella": "node scripts/test-treeshake-umbrella.mjs"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-virtual": "^3.0.2",
    "@solana/eslint-config-solana": "^6.0.0",
    "@solana/prettier-config-solana": "0.0.6",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "agadoo": "^3.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-jest": "^29.2.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "rollup": "^4.59.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.10"
  },
  "prettier": "@solana/prettier-config-solana",
  "pnpm": {
    "overrides": {
      "http-proxy-agent@5.0.0>@tootallnate/once": "3.0.1",
      "ajv@^6.0.0": "6.14.0",
      "bn.js@^5.0.0": "5.2.3",
      "brace-expansion@^1.0.0": "1.1.13",
      "brace-expansion@^2.0.0": "2.0.3",
      "fast-xml-parser@^5.0.0": "5.5.7",
      "flatted@^3.0.0": "3.4.2",
      "minimatch@^3.0.0": "3.1.4",
      "minimatch@^9.0.0": "9.0.7",
      "picomatch@^2.0.0": "2.3.2",
      "picomatch@^4.0.0": "4.0.4"
    }
  },
  "packageManager": "pnpm@10.14.0"
}
