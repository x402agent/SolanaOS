{
    "name": "@solana/keychain",
    "author": "Solana Foundation",
    "license": "MIT",
    "repository": "https://github.com/solana-foundation/solana-keychain",
    "version": "1.0.1",
    "description": "Unified Solana transaction signing across multiple backends",
    "keywords": [
        "solana",
        "signing",
        "wallet",
        "privy",
        "vault",
        "turnkey",
        "aws",
        "kms",
        "fireblocks",
        "cdp",
        "coinbase",
        "para",
        "dfns",
        "crossmint"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "tsc --build",
        "clean": "rm -rf dist *.tsbuildinfo",
        "prepack": "pnpm run build",
        "test": "vitest run && pnpm run typecheck",
        "typecheck": "tsc --noEmit",
        "test:treeshakability": "agadoo dist/index.js"
    },
    "dependencies": {
        "@solana/addresses": "^6.0.1",
        "@solana/keychain-core": "workspace:*",
        "@solana/keychain-aws-kms": "workspace:*",
        "@solana/keychain-cdp": "workspace:*",
        "@solana/keychain-crossmint": "workspace:*",
        "@solana/keychain-dfns": "workspace:*",
        "@solana/keychain-fireblocks": "workspace:*",
        "@solana/keychain-gcp-kms": "workspace:*",
        "@solana/keychain-para": "workspace:*",
        "@solana/keychain-privy": "workspace:*",
        "@solana/keychain-turnkey": "workspace:*",
        "@solana/keychain-vault": "workspace:*"
    },
    "peerDependencies": {
        "@solana/addresses": ">=6.0.1",
        "@solana/codecs-core": ">=6.0.1",
        "@solana/codecs-strings": ">=6.0.1",
        "@solana/keys": ">=6.0.1",
        "@solana/signers": ">=6.0.1",
        "@solana/transactions": ">=6.0.1"
    },
    "publishConfig": {
        "access": "public"
    }
}
