{
    "name": "@solana/keychain-core",
    "author": "Solana Foundation",
    "license": "MIT",
    "repository": "https://github.com/solana-foundation/solana-keychain",
    "version": "1.0.1",
    "description": "Core interfaces and types for external Solana signers",
    "keywords": [
        "solana",
        "signing",
        "wallet",
        "privy",
        "vault",
        "turnkey"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "tsc --build",
        "clean": "rm -rf dist *.tsbuildinfo",
        "prepack": "pnpm run build",
        "test": "vitest run && pnpm run typecheck",
        "typecheck": "tsc --noEmit",
        "test:treeshakability": "agadoo dist/index.js"
    },
    "peerDependencies": {
        "@solana/addresses": ">=6.0.1",
        "@solana/codecs-core": ">=6.0.1",
        "@solana/codecs-strings": ">=6.0.1",
        "@solana/keys": ">=6.0.1",
        "@solana/signers": ">=6.0.1",
        "@solana/transactions": ">=6.0.1"
    },
    "devDependencies": {
        "@solana/addresses": "^6.0.1",
        "@solana/codecs-core": "^6.0.1",
        "@solana/codecs-strings": "^6.0.1",
        "@solana/keys": "^6.0.1",
        "@solana/signers": "^6.0.1",
        "@solana/transactions": "^6.0.1",
        "vitest": "^4.0.10"
    },
    "publishConfig": {
        "access": "public"
    }
}
