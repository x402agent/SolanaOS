# ===========================================
# Solana OS - Git Ignore Configuration
# ===========================================

# Environment variables - NEVER commit these
.env
.env.local
.env.development
.env.staging
.env.production
.env.*.local
*.env

# Private keys and secrets
*.pem
*.key
*.secret
*private*.json
*credentials*.json
*keystore*.json
wallet*.json
keypair*.json

# Firebase credentials
google-services.json
*firebase-adminsdk*.json
GoogleService-Info.plist

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.cursor/
.cursor-server/
.cursor-workspace/
.cursor-settings.json

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# Test coverage
coverage/
.nyc_output/

# Logs
logs/
*.log

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Dependency directories
jspm_packages/
bower_components/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Expo
.expo/
.expo-shared/

# React Native
*.jsbundle
*.hmap
*.ipa
android/app/build/
ios/Pods/
ios/build/

# EAS
eas.json

# Sensitive app configs (these should be generated from examples)
app.json

# Backup files
*.backup
*.bak

# Solana specific
.anchor/
target/
test-ledger/
