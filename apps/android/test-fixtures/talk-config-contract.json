{
  "selectionCases": [
    {
      "id": "resolved-elevenlabs",
      "defaultProvider": "elevenlabs",
      "payloadValid": true,
      "talk": {
        "resolved": {
          "provider": "elevenlabs",
          "config": {
            "voiceId": "21m00Tcm4TlvDq8ikWAM",
            "apiKey": "sk-test-key-123"
          }
        }
      },
      "expectedSelection": {
        "provider": "elevenlabs",
        "normalizedPayload": true,
        "voiceId": "21m00Tcm4TlvDq8ikWAM",
        "apiKey": "sk-test-key-123"
      }
    },
    {
      "id": "resolved-provider-uppercase",
      "defaultProvider": "elevenlabs",
      "payloadValid": true,
      "talk": {
        "resolved": {
          "provider": "ElevenLabs",
          "config": {
            "voiceId": "voice-abc",
            "apiKey": "key-xyz"
          }
        }
      },
      "expectedSelection": {
        "provider": "elevenlabs",
        "normalizedPayload": true,
        "voiceId": "voice-abc",
        "apiKey": "key-xyz"
      }
    },
    {
      "id": "legacy-flat-keys",
      "defaultProvider": "elevenlabs",
      "payloadValid": true,
      "talk": {
        "voiceId": "legacy-voice-id",
        "apiKey": "legacy-api-key"
      },
      "expectedSelection": {
        "provider": "elevenlabs",
        "normalizedPayload": false,
        "voiceId": "legacy-voice-id",
        "apiKey": "legacy-api-key"
      }
    },
    {
      "id": "resolved-empty-config",
      "defaultProvider": "elevenlabs",
      "payloadValid": true,
      "talk": {
        "resolved": {
          "provider": "elevenlabs",
          "config": {}
        }
      },
      "expectedSelection": {
        "provider": "elevenlabs",
        "normalizedPayload": true,
        "voiceId": null,
        "apiKey": null
      }
    },
    {
      "id": "normalized-provider-without-resolved-returns-null",
      "defaultProvider": "elevenlabs",
      "payloadValid": true,
      "talk": {
        "provider": "elevenlabs"
      },
      "expectedSelection": null
    },
    {
      "id": "normalized-providers-without-resolved-returns-null",
      "defaultProvider": "elevenlabs",
      "payloadValid": true,
      "talk": {
        "providers": {
          "elevenlabs": {}
        }
      },
      "expectedSelection": null
    }
  ],
