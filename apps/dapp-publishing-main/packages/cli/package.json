{
  "name": "@solana-mobile/dapp-store-cli",
  "version": "0.16.0",
  "description": "Command-line interface for publishing to the Solana Mobile dApp Store",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "dapp-store": "./bin/dapp-store.js"
  },
  "files": [
    "lib",
    "bin",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solana-mobile/dapp-publishing-cli.git",
    "directory": "packages/cli"
  },
  "homepage": "https://docs.solanamobile.com/dapp-publishing/intro",
  "bugs": {
    "url": "https://github.com/solana-mobile/dapp-publishing-cli/issues"
  },
  "keywords": [
    "solana-mobile",
    "dapp-store",
    "publishing",
    "cli",
    "solana"
  ],
  "scripts": {
    "clean": "shx mkdir -p lib && shx rm -rf lib",
    "prebuild": "pnpm run clean && node src/prebuild_schema/schemagen.js",
    "prepack": "pnpm run prebuild && pnpm run build",
    "build:js": "swc src -d lib --copy-files",
    "build:types": "tsc --project tsconfig.json --emitDeclarationOnly --declaration --declarationMap --outDir lib",
    "build": "pnpm run build:js && pnpm run build:types",
    "watch": "swc src --out-dir lib -w",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "devDependencies": {
    "@jest/globals": "^29.5.0",
    "@jest/types": "^29.5.0",
    "@metaplex-foundation/js": "0.20.0",
    "@swc/jest": "^0.2.26",
    "@types/commander": "^2.12.2",
    "@types/debug": "^4.1.7",
    "@types/jest": "^29.5.1",
    "@types/js-yaml": "^4.0.5",
    "@types/terminal-link": "^1.2.0",
    "@types/update-notifier": "^6.0.1",
    "jest": "^29.5.0",
    "jest-transform-stub": "^2.0.0",
    "shx": "^0.3.4",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1"
  },
  "dependencies": {
    "@ardrive/turbo-sdk": "^1.41.0",
    "@aws-sdk/client-s3": "^3.321.1",
    "@metaplex-foundation/js-plugin-aws": "^0.20.0",
    "@solana-mobile/dapp-store-publishing-tools": "workspace:0.16.0",
    "@solana/web3.js": "1.92.1",
    "@types/semver": "^7.3.13",
    "ajv": "^8.11.0",
    "boxen": "^7.0.1",
    "bs58": "^5.0.0",
    "chokidar": "^3.5.3",
    "commander": "^9.4.1",
    "debug": "^4.3.4",
    "dotenv": "^16.0.3",
    "esm": "^3.2.25",
    "generate-schema": "^2.6.0",
    "get-video-dimensions": "^1.0.0",
    "image-size": "^1.0.2",
    "js-yaml": "^4.1.0",
    "semver": "^7.3.8",
    "terminal-link": "^3.0.0",
    "tweetnacl": "1.0.3",
    "update-notifier": "^6.0.2"
  }
}
