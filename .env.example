# ── x402 Payment Protocol ──────────────────────────────────────────────────────
X402_ENABLED=true
X402_FACILITATOR_URL=https://facilitator.x402.rs
X402_FACILITATOR_AUTHORIZATION=
X402_RECIPIENT_ADDRESS=
X402_PAYMENT_AMOUNT=0.001
X402_NETWORK=solana
X402_CHAINS=solana
X402_PAYWALL_ENABLED=false
X402_PAYWALL_PORT=18402
X402_PROXY_ENABLED=true
X402_PROXY_PORT=18403

# ── Bitaxe (local miner integration) ───────────────────────────────────────────
# Set BITAXE_HOST to connect the daemon directly to your miner.
BITAXE_ENABLED=false
BITAXE_HOST=
BITAXE_POLL_INTERVAL=10
BITAXE_POLL_INTERVAL_SEC=10
BITAXE_ALERTS_ENABLED=true
BITAXE_TEMP_WARNING=60
BITAXE_TEMP_CRITICAL=70
BITAXE_HASHRATE_MIN=0
BITAXE_ALERT_COOLDOWN=300

# Optional quickstart / autotune controls used by scripts/bitaxe-quickstart.sh
BITAXE_AUTO_TUNE=true
BITAXE_MAX_TEMP_C=72
BITAXE_COOL_TEMP_C=50
BITAXE_MAX_FREQ_MHZ=600
BITAXE_MIN_FREQ_MHZ=400
BITAXE_PET_NAME=MawdPet
BITAXE_POOL_URL=
BITAXE_POOL_PORT=
BITAXE_POOL_USER=

# ── Optional Remote MawdAxe Bridge ─────────────────────────────────────────────
# Use this when the main SolanaOS daemon is hosted on Fly, but the Bitaxe
# control plane stays on a LAN or Tailscale host that can actually reach the miner.
MAWDAXE_API_BASE=
MAWDAXE_API_KEY=
MAWDAXE_DEVICE_ID=

# ── OODA Trading Runtime ───────────────────────────────────────────────────────
OODA_MODE=live
OODA_INTERVAL_SECONDS=60
OODA_POSITION_SIZE_PCT=0.10
OODA_WATCHLIST=JUPyiwrYJFskUPiHa7hkeR8VUtAeFoSYbKedZNsDvCN,DezXAZ8z7PnrnRJjz3wXBoRgixCa6xjnB7YaB1pPB263,4k3Dyjzvzp8eMZWUXbBCjEvwSkkk59S5iCNLY3QrkX6R

# ── Headless Node Client / Hardware Nodes ──────────────────────────────────────
NODE_BRIDGE_ADDR=127.0.0.1:18790
NODE_DISPLAY_NAME=
NODE_DEVICE_FAMILY=
NODE_SESSION_KEY=main
NODE_TTS_ENGINE=none

# ── Native Gateway / Pairing / Tailnet Exposure ───────────────────────────────
GATEWAY_HOST=
GATEWAY_PORT=18790
GATEWAY_BIND=loopback
GATEWAY_AUTH_MODE=
GATEWAY_AUTH_TOKEN=
GATEWAY_AUTH_PASSWORD=
GATEWAY_AUTH_ALLOW_TAILSCALE=true
GATEWAY_TAILSCALE_MODE=off
GATEWAY_TAILSCALE_RESET_ON_EXIT=false

# Auto-spawn the native gateway in tmux.
GATEWAY_AUTO_SPAWN=false
GATEWAY_SPAWN_PORT=18790
GATEWAY_USE_TAILSCALE=true

# Legacy/manual gateway secret still accepted by some older flows.
NANO_GATEWAY_SECRET=

# Remote gateway / SSH tunnel defaults.
GATEWAY_REMOTE_MODE=local
GATEWAY_REMOTE_URL=
GATEWAY_REMOTE_TOKEN=
GATEWAY_REMOTE_PASSWORD=
GATEWAY_REMOTE_TLS_FINGERPRINT=
