GATEWAY_REMOTE_SSH_LOCAL_PORT=18790
GATEWAY_REMOTE_SSH_REMOTE_PORT=18790
GATEWAY_REMOTE_SSH_REMOTE_BIND_HOST=127.0.0.1
GATEWAY_REMOTE_SSH_LAUNCH_AGENT_LABEL=ai.nanosolana.ssh-tunnel

# Fly-specific gateway process defaults.
