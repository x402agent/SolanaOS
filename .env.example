# ── SolanaOS :: Root Environment Template ──────────────────────────────────────
# Copy this file to `.env` and fill in only the sections you need.
#
#   cp .env.example .env
#
# Startup profiles:
# 1. Local daemon only:
#    - SOLANA_TRACKER_RPC_URL or HELIUS_RPC_URL
#    - SOLANA_TRACKER_API_KEY (recommended)
#    - JUPITER_API_KEY (optional but recommended for swap/routing limits)
#    - TELEGRAM_BOT_TOKEN (if you want Telegram control)
#
# 2. NanoHub / seeker.solanaos.net:
#    - VITE_CONVEX_URL
#    - VITE_CONVEX_SITE_URL
#    - CONVEX_SITE_URL
#    - AUTH_GITHUB_ID / AUTH_GITHUB_SECRET
#    - JWT_PRIVATE_KEY / JWKS
#
# 3. Android direct AI builds:
#    - TOGETHER_API_KEY / TOGETHER_MODEL
#    - optionally XAI_API_KEY or OPENROUTER_API_KEY
#
# SolanaOS degrades gracefully when optional services are missing.

# ── Core Runtime Identity / Paths ──────────────────────────────────────────────
SOLANAOS_HOME=
SOLANAOS_CONFIG=
PORT=
SOLANAOS_PORT=
SOLANAOS_WEB_URL=
SOLANAOS_CONTROL_API_URL=

# ── Solana RPC / Market Data :: Helius ─────────────────────────────────────────
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_NETWORK=mainnet
HELIUS_TIMEOUT=20
HELIUS_RETRIES=3

# ── Solana RPC / Market Data :: Solana Tracker ────────────────────────────────
# SolanaTracker is the preferred default RPC/data provider for new installs.
# RPC docs: https://docs.solanatracker.io/solana-rpc
# Data API: https://docs.solanatracker.io/data-api
# Datastream: wss://datastream.solanatracker.io/{DATASTREAM_KEY}
SOLANA_TRACKER_API_KEY=
SOLANA_TRACKER_RPC_URL=https://rpc-mainnet.solanatracker.io/?api_key=YOUR_KEY
SOLANA_TRACKER_WSS_URL=wss://rpc-mainnet.solanatracker.io/?api_key=YOUR_KEY
# Alias used by Android build scripts.
SOLANA_TRACKER_WS_URL=
SOLANA_TRACKER_DATA_API_KEY=
SOLANA_TRACKER_DATASTREAM_KEY=

# ── Optional Extra Market Data ─────────────────────────────────────────────────
BIRDEYE_API_KEY=
BIRDEYE_WSS_URL=

# ── Jupiter (DEX Aggregator) ───────────────────────────────────────────────────
JUPITER_API_KEY=
JUPITER_ENDPOINT=https://api.jup.ag
JUPITER_ULTRA_ENDPOINT=https://api.jup.ag/ultra/v1
JUPITER_REFERRAL=
# Optional alternate env name used in some deploys / Android builds.
JUP_SWAP_V1_API_KEY=

# ── Perps :: Aster ─────────────────────────────────────────────────────────────
ASTER_API_KEY=
ASTER_API_SECRET=
ASTER_WALLET_ADDRESS=
ASTER_PRIVATE_KEY=
ASTER_USER_ADDRESS=
ASTER_SIGNER_ADDRESS=

# ── Perps :: Hyperliquid ───────────────────────────────────────────────────────
HYPERLIQUID_ENABLED=false
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_WALLET=
HYPERLIQUID_TESTNET=false
HYPERLIQUID_WS_ENABLED=true
HYPERLIQUID_SYMBOLS=BTC,ETH,SOL
HYPERLIQUID_TRIGGER_COOLDOWN_SEC=15
HYPERLIQUID_MARK_TRIGGER_BPS=25

# ── Solana Wallet / Position Limits ────────────────────────────────────────────
# If not set, SolanaOS can generate a wallet under ~/.nanosolana/.
SOLANA_PRIVATE_KEY=
SOLANA_WALLET_KEY_PATH=
SOLANA_WALLET_PUBKEY=
SOLANA_MIN_RESERVE_SOL=0.01
SOLANA_MAX_POSITION_SOL=0.5

# ── LLM Providers :: Hosted + Local ────────────────────────────────────────────
LLM_PROVIDER=openrouter

TOGETHER_API_KEY=
TOGETHER_MODEL=MiniMaxAI/MiniMax-M2.5
# Optional separate Together embedding configuration for NanoHub Convex actions.
TOGETHER_EMBEDDINGS_MODEL=intfloat/multilingual-e5-large-instruct
TOGETHER_EMBEDDINGS_ENDPOINT=https://api.together.xyz/v1/embeddings

OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m2.7
OPENROUTER_MODEL1=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL2=nousresearch/hermes-3-llama-3.1-405b:free
OPENROUTER_MODEL3=minimax/minimax-m2.5:free
OPENROUTER_FREE_MODELS=nvidia/nemotron-3-super-120b-a12b:free,nousresearch/hermes-3-llama-3.1-405b:free,minimax/minimax-m2.5:free
OPENROUTER_OPENAI_MODEL=openai/gpt-5.4-mini
OPENROUTER_GROK_MODEL=x-ai/grok-4.20-beta
OPENROUTER_MIMO_MODEL=
OPENROUTER_OMNI_MODEL=

XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast
XAI_SEARCH_MODEL=grok-4.20-reasoning
XAI_TOOL_MODEL=grok-4.20-beta-latest-non-reasoning
XAI_IMAGE_MODEL=grok-imagine-image
XAI_VIDEO_MODEL=grok-imagine-video
XAI_MULTI_AGENT_MODEL=grok-4.20-multi-agent-beta-0309

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MAX_TOKENS=2048
ANTHROPIC_BETAS=

OLLAMA_BASE_URL=http://host.docker.internal:11434
