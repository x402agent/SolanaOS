SOLANAOS_FLY_GATEWAY_PORT=18790
SOLANAOS_GATEWAY_HOST=
SOLANAOS_GATEWAY_PORT=
SOLANAOS_GATEWAY_TLS=false
SOLANAOS_FLEET_API_KEY=
SOLANAOS_WEBSITE_DIR=

