LEARNING_NUDGE_INTERVAL_MIN=720
LEARNING_AUTO_IMPROVE_SKILLS=true

# ── Honcho Memory Bridge (optional managed/self-hosted backend) ───────────────
HONCHO_ENABLED=false
# Preferred name; HONCHO_URL is still accepted as a backwards-compatible alias.
HONCHO_BASE_URL=https://api.honcho.dev
HONCHO_URL=
HONCHO_API_KEY=
HONCHO_WORKSPACE_ID=solanaos
HONCHO_AGENT_PEER_ID=solanaos-agent
HONCHO_REASONING_LEVEL=low
HONCHO_SESSION_STRATEGY=per-chat
HONCHO_CONTEXT_TOKENS=4000
HONCHO_CONTEXT_SUMMARY=true
HONCHO_SYNC_MESSAGES=true
HONCHO_DIALECTIC_ENABLED=true

# ── Scheduled Automations / Runtime / Delegation / Research ───────────────────
AUTOMATIONS_ENABLED=true
RUNTIME_DEFAULT_BACKEND=local
RUNTIME_SERVERLESS_PERSISTENCE=true
DELEGATION_ENABLED=true
DELEGATION_MAX_PARALLEL=3
DELEGATION_SCAFFOLD_PYTHON_RPC=true
