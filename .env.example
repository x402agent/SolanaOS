# ── Continuous Learning (SQLite FTS + user models + auto skills) ─────────────
LEARNING_ENABLED=true
LEARNING_SESSION_DB_PATH=
LEARNING_SEARCH_LIMIT=5
LEARNING_AUTO_SKILL_THRESHOLD=3
LEARNING_USER_MODEL_MAX_EVIDENCE=12
