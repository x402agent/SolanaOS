# ── Pinata Private IPFS Hub ───────────────────────────────────────────────────
# Central file storage for SolanaOS Hub — scoped per Solana wallet + GitHub account.
# Files are stored on Pinata Private IPFS and recalled via temporary access links.
# Cross-platform: web hub, Solana Seeker, Android app, Tailscale mesh nodes.
PINATA_ENABLED=false
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=
PINATA_GATEWAY=                          # e.g. your-gateway.mypinata.cloud
PINATA_MESH_SYNC=true                    # auto-distribute files across Tailscale/BLE mesh
PINATA_BLE_BRIDGE=                       # BLE bridge address (default 127.0.0.1:8765)

