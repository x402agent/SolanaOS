# ===========================================
# Solana OS - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control!

# ===========================================
# SOLANA NETWORK CONFIGURATION
# ===========================================
# Cluster: mainnet-beta, devnet, or testnet
CLUSTER=devnet

# Helius RPC Configuration (https://helius.dev)
HELIUS_RPC_CLUSTER=devnet
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_STAKED_URL=https://devnet.helius-rpc.com
HELIUS_STAKED_API_KEY=your_helius_staked_api_key_here

# Alternative RPC URL (optional, overrides Helius)
RPC_URL=

# ===========================================
# $OS TOKEN CONFIGURATION
# ===========================================
# Official $OS Token Mint Address on Solana
OS_TOKEN_MINT=DrU9M6SUaXWua49zeaHQWJuwMpcZ4jMDRT3J5Ywpump

# Minimum $OS holdings required for developer rewards (in tokens)
OS_MIN_HOLDING_FOR_REWARDS=1000

# Developer rewards pool wallet (receives fees, distributes rewards)
OS_REWARDS_POOL_WALLET=

# ===========================================
# WALLET PROVIDER CONFIGURATION
# ===========================================
# Privy (https://privy.io)
PRIVY_APP_ID=your_privy_app_id
PRIVY_CLIENT_ID=your_privy_client_id

# Dynamic (https://dynamic.xyz)
DYNAMIC_API_KEY=your_dynamic_api_key
DYNAMIC_ENVIRONMENT_ID=your_dynamic_environment_id

# Turnkey (https://turnkey.com)
TURNKEY_BASE_URL=https://api.turnkey.com
TURNKEY_RP_ID=your_turnkey_rp_id
TURNKEY_RP_NAME=Solana OS
TURNKEY_ORGANIZATION_ID=your_turnkey_org_id

# ===========================================
# API KEYS
# ===========================================
# OpenAI for AI features
OPENAI_API_KEY=your_openai_api_key

# Token data providers
BIRDEYE_API_KEY=your_birdeye_api_key
COINGECKO_API_KEY=your_coingecko_api_key
TENSOR_API_KEY=your_tensor_api_key

# Fiat on-ramp
MOONPAY_API_KEY=your_moonpay_api_key

# ===========================================
# SERVER CONFIGURATION
# ===========================================
SERVER_URL=http://localhost:8080

# Token Mill Program Configuration
TOKEN_MILL_CONFIG_PDA=your_token_mill_config_pda

# Commission wallet for platform fees
COMMISSION_WALLET=your_commission_wallet_address
