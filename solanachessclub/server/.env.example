# ===========================================
# Solana OS Server - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control!

# ===========================================
# SERVER CONFIGURATION
# ===========================================
NODE_ENV=development
PORT=8080

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/solana_os

# Supabase (optional, for cloud hosting)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_PROJECT_ID=your_project_id

# ===========================================
# AUTHENTICATION (REQUIRED - NO DEFAULTS)
# ===========================================
# Admin credentials - MUST be set, no fallbacks for security
ADMIN_USERNAME=your_admin_username
# Generate password hash with: node -e "console.log(require('bcrypt').hashSync('your_password', 10))"
ADMIN_PASSWORD_HASH=your_bcrypt_password_hash
# Generate a secure random string (minimum 32 characters)
JWT_SECRET=your_super_secure_jwt_secret_minimum_32_chars

# ===========================================
# SOLANA NETWORK CONFIGURATION
# ===========================================
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Helius RPC (recommended for production)
HELIUS_STAKED_URL=https://devnet.helius-rpc.com
HELIUS_API_KEY=your_helius_api_key

# ===========================================
# $OS TOKEN CONFIGURATION
# ===========================================
# Official $OS Token Mint Address
OS_TOKEN_MINT=DrU9M6SUaXWua49zeaHQWJuwMpcZ4jMDRT3J5Ywpump

# Developer rewards configuration
OS_MIN_HOLDING_FOR_REWARDS=1000
OS_REWARDS_POOL_WALLET=your_rewards_pool_wallet
OS_DEPLOYMENT_FEE=100

# Agent deployment configuration
OS_AGENT_DEPLOYMENT_FEE=500
OS_APP_DEPLOYMENT_FEE=1000

# ===========================================
# TURNKEY AUTHENTICATION
# ===========================================
TURNKEY_API_URL=https://api.turnkey.com
TURNKEY_ORGANIZATION_ID=your_org_id
TURNKEY_API_PUBLIC_KEY=your_public_key
TURNKEY_API_PRIVATE_KEY=your_private_key

# ===========================================
# EXTERNAL SERVICES
# ===========================================
# IPFS Storage (Pinata)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# AI Services
OPENAI_API_KEY=your_openai_api_key

# ===========================================
# OPTIONAL: WALLET PRIVATE KEY
# ===========================================
# WARNING: Only use for server-side signing operations
# NEVER commit this value to version control
# WALLET_PRIVATE_KEY=your_base58_encoded_private_key
